# Conformance and release-gate env contract.
# This is the same env contract used by the SDK Conformance & Verification
# workflow, the release-gate workflow, and server/run.sh local bootstrap.
# See server/docs/release-gate.md for the authoritative contract description.

TOOLPLANE_CONFORMANCE_AUTO_BOOT=1

TOOLPLANE_ENV_MODE=development
TOOLPLANE_AUTH_MODE=fixed
TOOLPLANE_AUTH_FIXED_API_KEY=toolplane-conformance-fixture-key
TOOLPLANE_STORAGE_MODE=memory
TOOLPLANE_PROXY_ALLOW_INSECURE_BACKEND=1

# If auto boot is disabled, these are used directly.
TOOLPLANE_CONFORMANCE_GRPC_HOST=localhost
TOOLPLANE_CONFORMANCE_GRPC_PORT=50051
TOOLPLANE_CONFORMANCE_HTTP_HOST=localhost
TOOLPLANE_CONFORMANCE_HTTP_PORT=8080

# Non-secret fixture token used by local conformance and CI.
TOOLPLANE_CONFORMANCE_API_KEY=toolplane-conformance-fixture-key

# User ID used by conformance fixtures.
TOOLPLANE_CONFORMANCE_USER_ID=conformance-user
