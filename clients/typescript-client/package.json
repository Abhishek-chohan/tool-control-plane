{
  "name": "toolplane-typescript-client",
  "version": "1.0.0",
  "description": "TypeScript gRPC client for the Toolplane control plane",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && node scripts/copy-proto-assets.mjs",
    "lint": "eslint --max-warnings=0 \"src/**/*.ts\" \"tests/**/*.ts\"",
    "start": "node dist/client.js",
    "dev": "ts-node src/client.ts",
    "example": "ts-node src/examples/basic_example.ts",
    "advanced": "ts-node src/examples/advanced_example.ts",
    "generate:proto": "grpc_tools_node_protoc --js_out=import_style=commonjs,binary:./src/proto --grpc_out=grpc_js:./src/proto --ts_out=grpc_js:./src/proto -I . proto/service.proto google/api/annotations.proto google/api/http.proto",
    "test": "npm run test:unit",
    "test:unit": "node scripts/run-tests.mjs tests/unit",
    "test:conformance": "npm run build && node scripts/run-tests.mjs tests/conformance",
    "test:all": "npm run test:unit && npm run test:conformance",
    "test:demo": "npm run build && node dist/client.js"
  },
  "keywords": [
    "rpc",
    "grpc",
    "typescript",
    "client"
  ],
  "author": "Toolplane Team",
  "license": "Apache-2.0",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "@types/node": "^20.0.0",
    "eslint": "^8.57.1",
    "grpc-tools": "^1.13.0",
    "grpc_tools_node_protoc_ts": "^5.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.0.0",
    "ts-node": "^10.9.0"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.1",
    "axios": "^1.6.0",
    "google-protobuf": "^3.21.4",
    "uuid": "^9.0.0",
    "@types/uuid": "^9.0.0"
  }
}