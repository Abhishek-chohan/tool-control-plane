# Local development defaults for the supported bootstrap path.

TOOLPLANE_ENV_MODE=development
TOOLPLANE_AUTH_MODE=fixed
TOOLPLANE_AUTH_FIXED_API_KEY=toolplane-conformance-fixture-key
TOOLPLANE_STORAGE_MODE=memory
TOOLPLANE_PROXY_ALLOW_INSECURE_BACKEND=1
TOOLPLANE_PROXY_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080

# Production-like auth example.
# TOOLPLANE_AUTH_MODE=postgres
# TOOLPLANE_STORAGE_MODE=postgres
# TOOLPLANE_DATABASE_URL=postgres://username:password@localhost:5432/toolplane?sslmode=disable

# Persistent storage example.
# TOOLPLANE_STORAGE_MODE=postgres
# TOOLPLANE_DATABASE_URL=postgres://username:password@localhost:5432/toolplane?sslmode=disable

# Optional debug logging for auth validators.
# TOOLPLANE_AUTH_DEBUG=1

# Optional proxy TLS server-name override when TOOLPLANE_PROXY_ALLOW_INSECURE_BACKEND=0.
# TOOLPLANE_PROXY_BACKEND_TLS_SERVER_NAME=localhost