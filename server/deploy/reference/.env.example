# Reference deployment defaults for server/deploy/reference/compose.yaml.

TOOLPLANE_IMAGE=toolplane-reference:latest

POSTGRES_USER=toolplane
POSTGRES_PASSWORD=toolplane
POSTGRES_DB=toolplane
TOOLPLANE_DATABASE_URL=postgres://toolplane:toolplane@postgres:5432/toolplane?sslmode=disable

TOOLPLANE_POSTGRES_PUBLISHED_PORT=5432
TOOLPLANE_GRPC_PUBLISHED_PORT=9001
TOOLPLANE_HTTP_PUBLISHED_PORT=8080
TOOLPLANE_METRICS_PUBLISHED_PORT=9102
TOOLPLANE_BOOTSTRAP_HTTP_PUBLISHED_PORT=18080

TOOLPLANE_SERVER_TLS_CERT_PATH=./certs/server.crt
TOOLPLANE_SERVER_TLS_KEY_PATH=./certs/server.key
TOOLPLANE_PROXY_BACKEND_TLS_CA_PATH=./certs/ca.crt

TOOLPLANE_PROXY_ALLOWED_ORIGINS=https://app.example.com
TOOLPLANE_PROXY_BACKEND_TLS_SERVER_NAME=server

TOOLPLANE_PROXY_API_RATE=25
TOOLPLANE_PROXY_API_BURST=50
TOOLPLANE_PROXY_IP_RATE=100
TOOLPLANE_PROXY_IP_BURST=200

# One-time fixed token used only by the bootstrap profile.
TOOLPLANE_BOOTSTRAP_FIXED_API_KEY=replace-this-one-time-bootstrap-token